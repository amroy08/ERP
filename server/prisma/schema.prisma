generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  password     String
  role         Role
  profilePhoto String?
  phone        String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  refreshToken String?   @db.Text
  schoolId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  parent       Parent?
  staff        Staff?
  student      Student?
  teacher      Teacher?
  supportTickets SupportTicket[]
  school       School?   @relation("UserSchool", fields: [schoolId], references: [id])

  @@index([schoolId], map: "users_schoolId_fkey")
  @@map("users")
}

model AcademicYear {
  id            String         @id @default(uuid())
  name          String
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean        @default(false)
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  school        School?        @relation("AcademicYearSchool", fields: [schoolId], references: [id])
  admissions    Admission[]
  exams         Exam[]
  feeStructures FeeStructure[]
  students      Student[]

  @@unique([name, schoolId])
  @@index([schoolId], map: "academic_years_schoolId_fkey")
  @@map("academic_years")
}

model Class {
  id            String         @id @default(uuid())
  name          String
  numericValue  Int
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  admissions    Admission[]
  school        School?        @relation("ClassSchool", fields: [schoolId], references: [id])
  exams         Exam[]
  feeStructures FeeStructure[]
  homework      Homework[]
  sections      Section[]
  students      Student[]
  subjects      Subject[]
  timetables    Timetable[]
  teachers      Teacher[]      @relation("ClassToTeacher")

  @@unique([name, schoolId])
  @@index([schoolId], map: "classes_schoolId_fkey")
  @@map("classes")
}

model Section {
  id             String      @id @default(uuid())
  name           String
  capacity       Int         @default(40)
  classId        String
  classTeacherId String?
  schoolId       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  admissions     Admission[]
  homework       Homework[]
  class          Class       @relation(fields: [classId], references: [id])
  classTeacher   Teacher?    @relation("ClassTeacherOf", fields: [classTeacherId], references: [id])
  school         School?     @relation(fields: [schoolId], references: [id])
  students       Student[]
  timetables     Timetable[]

  @@index([classId], map: "sections_classId_fkey")
  @@index([classTeacherId], map: "sections_classTeacherId_fkey")
  @@index([schoolId], map: "sections_schoolId_fkey")
  @@map("sections")
}

model Subject {
  id               String           @id @default(uuid())
  name             String
  code             String           @unique
  type             String           @default("theory")
  classId          String
  teacherId        String?
  isOptional       Boolean          @default(false)
  isActive         Boolean          @default(true)
  schoolId         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  homework         Homework[]
  results          Result[]
  class            Class            @relation(fields: [classId], references: [id])
  school           School?          @relation(fields: [schoolId], references: [id])
  teacher          Teacher?         @relation(fields: [teacherId], references: [id])
  timetableEntries TimetableEntry[]

  @@index([classId], map: "subjects_classId_fkey")
  @@index([schoolId], map: "subjects_schoolId_fkey")
  @@index([teacherId], map: "subjects_teacherId_fkey")
  @@map("subjects")
}

model Student {
  id              String         @id @default(uuid())
  admissionNumber String         @unique
  rollNumber      String?
  userId          String?        @unique
  firstName       String
  lastName        String
  fullName        String
  dateOfBirth     DateTime
  gender          Gender
  bloodGroup      String?
  religion        String?
  category        String?        @default("general")
  parentId        String
  classId         String
  sectionId       String
  academicYearId  String
  schoolId        String?
  status          String         @default("active")
  addressStreet   String?
  addressCity     String?
  addressState    String?
  addressPincode  String?
  emergencyName   String?
  emergencyPhone  String?
  emergencyRel    String?
  house           String?
  previousSchool  String?
  aadhaarNumber   String?
  medicalNote     String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  activityLogs    ActivityLog[]
  attendance      Attendance[]
  feePayments     FeePayment[]
  leaveRequests   LeaveRequest[]
  results         Result[]
  assignedFees    StudentFee[]
  academicYear    AcademicYear   @relation(fields: [academicYearId], references: [id])
  class           Class          @relation(fields: [classId], references: [id])
  parent          Parent         @relation(fields: [parentId], references: [id])
  school          School?        @relation(fields: [schoolId], references: [id])
  section         Section        @relation(fields: [sectionId], references: [id])
  user            User?          @relation(fields: [userId], references: [id])

  @@index([academicYearId], map: "students_academicYearId_fkey")
  @@index([classId], map: "students_classId_fkey")
  @@index([parentId], map: "students_parentId_fkey")
  @@index([schoolId], map: "students_schoolId_fkey")
  @@index([sectionId], map: "students_sectionId_fkey")
  @@map("students")
}

model Parent {
  id           String    @id @default(uuid())
  userId       String?   @unique
  fatherName   String
  fatherOccupation String?
  fatherPhone  String
  motherName   String?
  motherOccupation String?
  motherPhone  String?
  annualIncome Float?
  address      String?   @db.Text
  schoolId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  school       School?   @relation(fields: [schoolId], references: [id])
  user         User?     @relation(fields: [userId], references: [id])
  children     Student[]

  @@index([schoolId], map: "parents_schoolId_fkey")
  @@map("parents")
}

model Teacher {
  id                 String           @id @default(uuid())
  userId             String           @unique
  employeeId         String           @unique
  designation        String
  qualification      String
  experience         Int?             @default(0)
  joiningDate        DateTime
  specialization     String?
  status             String           @default("active")
  canViewAllStudents Boolean          @default(false)
  schoolId           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  homework           Homework[]
  classTeacherOf     Section[]        @relation("ClassTeacherOf")
  subjects           Subject[]
  school             School?          @relation(fields: [schoolId], references: [id])
  user               User             @relation(fields: [userId], references: [id])
  timetableEntries   TimetableEntry[]
  assignedClasses    Class[]          @relation("ClassToTeacher")

  @@index([schoolId], map: "teachers_schoolId_fkey")
  @@map("teachers")
}

model Staff {
  id          String   @id @default(uuid())
  userId      String   @unique
  employeeId  String   @unique
  department  String
  designation String
  joiningDate DateTime
  status      String   @default("active")
  schoolId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([schoolId], map: "staff_schoolId_fkey")
  @@map("staff")
}

model Attendance {
  id        String   @id @default(uuid())
  date      DateTime
  status    String
  studentId String
  remark    String?
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School?  @relation(fields: [schoolId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([date, studentId])
  @@index([schoolId], map: "attendance_schoolId_fkey")
  @@index([studentId], map: "attendance_studentId_fkey")
  @@map("attendance")
}

model Exam {
  id             String       @id @default(uuid())
  name           String
  type           String
  classId        String
  academicYearId String
  startDate      DateTime
  endDate        DateTime
  status         String       @default("scheduled")
  description    String?      @db.Text
  fileUrl        String?
  schoolId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  class          Class        @relation(fields: [classId], references: [id])
  school         School?      @relation(fields: [schoolId], references: [id])
  results        Result[]

  @@index([academicYearId], map: "exams_academicYearId_fkey")
  @@index([classId], map: "exams_classId_fkey")
  @@index([schoolId], map: "exams_schoolId_fkey")
  @@map("exams")
}

model Result {
  id            String   @id @default(uuid())
  examId        String
  studentId     String
  subjectId     String
  marksObtained Int
  maxMarks      Int
  grade         String?
  remark        String?
  schoolId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id])
  school        School?  @relation(fields: [schoolId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])
  subject       Subject  @relation(fields: [subjectId], references: [id])

  @@unique([examId, studentId, subjectId])
  @@index([schoolId], map: "results_schoolId_fkey")
  @@index([studentId], map: "results_studentId_fkey")
  @@index([subjectId], map: "results_subjectId_fkey")
  @@map("results")
}

model FeeStructure {
  id             String         @id @default(uuid())
  classId        String?
  academicYearId String?
  name           String
  components     Json?
  totalAmount    Float          @default(0)
  description    String?        @db.Text
  isActive       Boolean        @default(true)
  schoolId       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  admissions     AdmissionFee[]
  academicYear   AcademicYear?  @relation(fields: [academicYearId], references: [id])
  class          Class?         @relation(fields: [classId], references: [id])
  school         School?        @relation(fields: [schoolId], references: [id])
  students       StudentFee[]

  @@index([academicYearId], map: "fee_structures_academicYearId_fkey")
  @@index([classId], map: "fee_structures_classId_fkey")
  @@index([schoolId], map: "fee_structures_schoolId_fkey")
  @@map("fee_structures")
}

model StudentFee {
  id             String       @id @default(uuid())
  studentId      String
  feeStructureId String
  customAmount   Float?
  status         String       @default("pending")
  academicYearId String?
  schoolId       String?
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  school         School?      @relation(fields: [schoolId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, feeStructureId, academicYearId])
  @@index([feeStructureId], map: "student_fees_feeStructureId_fkey")
  @@index([schoolId], map: "student_fees_schoolId_fkey")
  @@map("student_fees")
}

model FeePayment {
  id             String   @id @default(uuid())
  studentId      String
  amountPaid     Float
  paymentDate    DateTime @default(now())
  paymentMode    String
  receiptNumber  String   @unique
  status         String   @default("completed")
  remarks        String?
  academicYearId String?
  schoolId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  school         School?  @relation(fields: [schoolId], references: [id])
  student        Student  @relation(fields: [studentId], references: [id])

  @@index([schoolId], map: "fee_payments_schoolId_fkey")
  @@index([studentId], map: "fee_payments_studentId_fkey")
  @@map("fee_payments")
}

model Archive {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  entityName String?
  data       Json
  deletedAt  DateTime @default(now())
  deletedBy  String?

  @@map("archives")
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.LongText
  targetRoles String
  priority    String   @default("normal")
  type        String   @default("text")
  fileUrl     String?
  publishDate DateTime @default(now())
  isPublished Boolean  @default(true)
  createdBy   String?
  schoolId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id])

  @@index([schoolId], map: "notices_schoolId_fkey")
  @@map("notices")
}

model Enquiry {
  id          String   @id @default(uuid())
  studentName String
  parentName  String
  phone       String
  email       String?
  class       String?
  message     String?  @db.Text
  status      String   @default("new")
  source      String?
  schoolId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id])

  @@index([schoolId], map: "enquiries_schoolId_fkey")
  @@map("enquiries")
}

model Admission {
  id             String         @id @default(uuid())
  applicationNo  String         @unique
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  gender         Gender
  classId        String
  academicYearId String
  parentName     String
  parentPhone    String
  parentEmail    String?
  fatherName     String?
  fatherPhone    String?
  motherName     String?
  motherPhone    String?
  aadhaarNumber  String?
  address        String?
  status         String         @default("new")
  previousSchool String?
  remarks        String?
  sectionId      String?
  schoolId       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assignedFees   AdmissionFee[]
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])
  class          Class          @relation(fields: [classId], references: [id])
  school         School?        @relation(fields: [schoolId], references: [id])
  section        Section?       @relation(fields: [sectionId], references: [id])

  @@index([academicYearId], map: "admissions_academicYearId_fkey")
  @@index([classId], map: "admissions_classId_fkey")
  @@index([schoolId], map: "admissions_schoolId_fkey")
  @@index([sectionId], map: "admissions_sectionId_fkey")
  @@map("admissions")
}

model AdmissionFee {
  id             String       @id @default(uuid())
  admissionId    String
  feeStructureId String
  customAmount   Float?
  admission      Admission    @relation(fields: [admissionId], references: [id])
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])

  @@unique([admissionId, feeStructureId])
  @@index([feeStructureId], map: "admission_fees_feeStructureId_fkey")
  @@map("admission_fees")
}

model Timetable {
  id             String           @id @default(uuid())
  classId        String
  sectionId      String
  academicYearId String           @default("")
  isActive       Boolean          @default(true)
  fileUrl        String?
  notes          String?          @db.Text
  schoolId       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  entries        TimetableEntry[]
  class          Class            @relation(fields: [classId], references: [id])
  school         School?          @relation(fields: [schoolId], references: [id])
  section        Section          @relation(fields: [sectionId], references: [id])

  @@unique([sectionId, academicYearId])
  @@index([classId], map: "timetables_classId_fkey")
  @@index([schoolId], map: "timetables_schoolId_fkey")
  @@map("timetables")
}

model TimetableEntry {
  id          String    @id @default(uuid())
  timetableId String
  day         String
  subjectId   String
  teacherId   String
  startTime   String
  endTime     String
  room        String?
  subject     Subject   @relation(fields: [subjectId], references: [id])
  teacher     Teacher   @relation(fields: [teacherId], references: [id])
  timetable   Timetable @relation(fields: [timetableId], references: [id])

  @@index([subjectId], map: "timetable_entries_subjectId_fkey")
  @@index([teacherId], map: "timetable_entries_teacherId_fkey")
  @@index([timetableId], map: "timetable_entries_timetableId_fkey")
  @@map("timetable_entries")
}

model Homework {
  id           String   @id @default(uuid())
  title        String
  description  String   @db.Text
  classId      String
  sectionId    String?
  subjectId    String
  assignedDate DateTime @default(now())
  dueDate      DateTime
  assignedById String
  attachments  String?  @db.Text
  fileUrl      String?
  schoolId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignedBy   Teacher  @relation(fields: [assignedById], references: [id])
  class        Class    @relation(fields: [classId], references: [id])
  school       School?  @relation(fields: [schoolId], references: [id])
  section      Section? @relation(fields: [sectionId], references: [id])
  subject      Subject  @relation(fields: [subjectId], references: [id])

  @@index([assignedById], map: "homework_assignedById_fkey")
  @@index([classId], map: "homework_classId_fkey")
  @@index([schoolId], map: "homework_schoolId_fkey")
  @@index([sectionId], map: "homework_sectionId_fkey")
  @@index([subjectId], map: "homework_subjectId_fkey")
  @@map("homework")
}

model School {
  id             String         @id @default(uuid())
  name           String
  address        String         @db.Text
  phone          String
  email          String
  website        String?
  logo           String?
  principal      String?
  affiliation    String?
  tagline        String?
  slug           String?        @unique
  enabledModules Json?
  licensedRoles  Json?
  licensePlan    String?        @default("enterprise")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  academicYears  AcademicYear[] @relation("AcademicYearSchool")
  activityLogs   ActivityLog[]
  admissions     Admission[]
  attendance     Attendance[]
  classes        Class[]        @relation("ClassSchool")
  enquiries      Enquiry[]
  exams          Exam[]
  feePayments    FeePayment[]
  feeStructures  FeeStructure[]
  homeworks      Homework[]
  leaveRequests  LeaveRequest[]
  notices        Notice[]
  parents        Parent[]
  results        Result[]
  sections       Section[]
  staff          Staff[]
  studentFees    StudentFee[]
  students       Student[]
  subjects       Subject[]
  supportTickets SupportTicket[]
  teachers       Teacher[]
  timetables     Timetable[]
  transportRoutes TransportRoute[]
  vehicles       Vehicle[]
  users          User[]         @relation("UserSchool")

  @@map("school_settings")
}

model LeaveRequest {
  id         String   @id @default(uuid())
  studentId  String
  type       String
  startDate  DateTime
  endDate    DateTime
  reason     String?  @db.Text
  status     String   @default("pending")
  remarks    String?
  approvedBy String?
  schoolId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  school     School?  @relation(fields: [schoolId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id])

  @@index([schoolId], map: "leave_requests_schoolId_fkey")
  @@index([studentId], map: "leave_requests_studentId_fkey")
  @@map("leave_requests")
}

model ActivityLog {
  id          String   @id @default(uuid())
  studentId   String
  action      String
  description String?  @db.Text
  performedBy String?
  schoolId    String?
  createdAt   DateTime @default(now())
  school      School?  @relation(fields: [schoolId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  @@index([schoolId], map: "activity_logs_schoolId_fkey")
  @@index([studentId], map: "activity_logs_studentId_fkey")
  @@map("activity_logs")
}

model Vehicle {
  id            String           @id @default(uuid())
  vehicleNumber String           @unique
  vehicleModel  String
  driverName    String
  driverPhone   String
  capacity      Int
  status        String           @default("active")
  schoolId      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  routes        TransportRoute[]
  school        School?          @relation(fields: [schoolId], references: [id])

  @@map("vehicles")
}

model TransportRoute {
  id          String   @id @default(uuid())
  routeName   String
  vehicleId   String?
  stops       Json?
  description String?  @db.Text
  schoolId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id])
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])

  @@map("transport_routes")
}

model SupportTicket {
  id        String   @id @default(uuid())
  subject   String
  message   String   @db.Text
  status    String   @default("open")
  userId    String
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  school    School?  @relation(fields: [schoolId], references: [id])

  @@map("support_tickets")
}

enum Role {
  super_admin
  admin
  principal
  teacher
  clerk
  parent
  student
}

enum Gender {
  male
  female
  other
}
